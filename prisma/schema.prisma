generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Store {
  id              String      @id @default(cuid())
  slug            String      @unique
  name            String
  logoUrl         String?
  googlePlaceId   String?
  stripeAccountId String?
  createdAt       DateTime    @default(now())
  staff           Staff[]
  tips            Tip[]
  admins          AdminUser[]
}

model Staff {
  id        String   @id @default(cuid())
  storeId   String
  name      String
  photoUrl  String?
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  tips      Tip[]

  @@index([storeId])
}

enum TipStatus {
  pending
  succeeded
  failed
}

model Tip {
  id                    String    @id @default(cuid())
  storeId               String
  staffId               String
  amount                Int
  locale                String
  status                TipStatus @default(pending)
  stripePaymentIntentId String?   @unique
  createdAt             DateTime  @default(now())
  store                 Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  staff                 Staff     @relation(fields: [staffId], references: [id], onDelete: Cascade)
  review                Review?

  @@index([storeId])
  @@index([staffId])
}

model Review {
  id                 String   @id @default(cuid())
  tipId              String   @unique
  storeId            String
  rating             Int
  comment            String?
  redirectedToGoogle Boolean  @default(false)
  createdAt          DateTime @default(now())
  tip                Tip      @relation(fields: [tipId], references: [id], onDelete: Cascade)

  @@index([storeId])
}

model AdminUser {
  id             String   @id @default(cuid())
  storeId        String
  supabaseUserId String   @unique
  role           String   @default("owner")
  createdAt      DateTime @default(now())
  store          Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
}

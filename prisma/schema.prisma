generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Store {
  id            String      @id @default(cuid())
  slug          String      @unique
  name          String
  logoUrl       String?
  googlePlaceId String?
  instagramUrl  String?
  facebookUrl   String?
  createdAt     DateTime    @default(now())
  staff         Staff[]
  tips          Tip[]
  admins        AdminUser[]
}

model Staff {
  id        String   @id @default(cuid())
  storeId   String
  name      String
  photoUrl  String?
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  tips      Tip[]

  @@index([storeId])
}

enum TipStatus {
  pending
  succeeded
  failed
}

enum PaymentMethod {
  cash
  card
}

model Tip {
  id                    String        @id @default(cuid())
  storeId               String
  staffId               String?
  amount                Int
  locale                String
  paymentMethod         PaymentMethod @default(cash)
  status                TipStatus     @default(pending)
  stripePaymentIntentId String?       @unique
  createdAt             DateTime      @default(now())
  store                 Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  staff                 Staff?        @relation(fields: [staffId], references: [id], onDelete: SetNull)
  review                Review?
  notificationReads     NotificationRead[]

  @@index([storeId])
  @@index([staffId])
}

model Review {
  id                 String   @id @default(cuid())
  tipId              String   @unique
  storeId            String
  rating             Int
  comment            String?
  photoUrls          String[] @default([])
  redirectedToGoogle Boolean  @default(false)
  createdAt          DateTime @default(now())
  tip                Tip      @relation(fields: [tipId], references: [id], onDelete: Cascade)

  @@index([storeId])
}

model AdminUser {
  id                String             @id @default(cuid())
  storeId           String
  supabaseUserId    String             @unique
  email             String             @unique
  role              String             @default("owner")
  createdAt         DateTime           @default(now())
  store             Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  notificationReads NotificationRead[]

  @@index([storeId])
}

/** Per-admin "this notification has been read" marker (set when its modal opens). */
model NotificationRead {
  id          String    @id @default(cuid())
  adminUserId String
  tipId       String
  createdAt   DateTime  @default(now())
  admin       AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  tip         Tip       @relation(fields: [tipId], references: [id], onDelete: Cascade)

  @@unique([adminUserId, tipId])
  @@index([adminUserId])
}
